<!--
  Parent Account Password Reset Template - Handlebars (.hbs)

  @purpose
    HTML template used for sending password reset emails to parents.
    It provides updated login credentials and a secure reset link valid for a short period.

  @params
    {{name}}       : string
      - Parent's name for personalization.
    {{userName}}   : string
      - Username for the parent account.
    {{password}}   : string
      - Temporary password for the parent account.
    {{resetLink}}  : string
      - Secure URL to reset the password. Typically valid for 10 minutes.
  @returns
    HTML content as a string after rendering with Handlebars.
  @throws
    None in template itself; errors may occur during rendering if required variables are missing.
  @sideEffects
    None in template itself.

  @example
    import Handlebars from 'handlebars';
    import fs from 'fs';
    
    const templateHtml = fs.readFileSync('parentResetTemplate.hbs', 'utf-8');
    const template = Handlebars.compile(templateHtml);
    const html = template({
      name: 'Jane Doe',
      userName: 'janedoe',
      password: 'TempPass456!',
      resetLink: 'https://portal.Institution.com/reset-password?token=xyz789'
    });
    
    // html now contains rendered HTML ready to send via email
-->
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Parent Account Password Reset</title>
  </head>
  <body
    style="font-family: Arial, sans-serif; background-color: #f4f4f4; margin: 0; padding: 20px;"
  >
    <div
      style="max-width: 800px; margin: auto; background: #fff; border-radius: 6px; box-shadow: 0 0 10px rgba(0,0,0,0.1); overflow: hidden;"
    >
      <div style="padding: 20px; box-sizing: border-box;">
        <h2 style="margin-top: 0; color: #333;">Reset Your Institutiontution
          Management Password</h2>
        <p>Hello {{name}},</p>

        <p>
          We’ve received a request to reset your parent account password on
          <strong>Institution</strong>. Below are your updated login
          credentials:
        </p>

        <ul
          style="background-color: #f9f9f9; padding: 15px; border-radius: 5px; list-style-type: none;"
        >
          <li><strong>Username:</strong> {{userName}}</li>
          <li><strong>Password:</strong> {{password}}</li>
        </ul>

        <p>
          To complete the process, please click the button below to reset your
          password. This link is valid for
          <strong>10 minutes</strong>:
        </p>

        <p style="text-align: center;">
          <a
            href="{{resetLink}}"
            target="_blank"
            style="background-color: #008cba; color: white; padding: 12px 20px; text-decoration: none; border-radius: 5px; display: inline-block; font-weight: bold;"
          >
            Reset Password
          </a>
        </p>

        <p>
          If you didn’t request this, please ignore this email.
        </p>

        <p>Warm Regards,<br />Institution</p>
      </div>
    </div>
  </body>
</html>