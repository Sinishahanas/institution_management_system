<!--
  Invoice Template - Handlebars (.hbs)

  @purpose
    HTML template used for generating invoice PDFs or emails for parents of students.
    Designed to be rendered with dynamic data like invoiceNumber, student details, etc.

  @params
    {{invoiceNumber}} : string
      - The unique invoice number to display in the header and title.
    (Optional) Additional Handlebars variables can be passed if template extended.
  @returns
    HTML content as string after rendering with Handlebars.
  @throws
    None; errors occur during rendering if required variables are missing.
  @sideEffects
    None.

  @example
    import Handlebars from 'handlebars';
    import fs from 'fs';
    
    const templateHtml = fs.readFileSync('invoiceTemplate.hbs', 'utf-8');
    const template = Handlebars.compile(templateHtml);
    const html = template({ invoiceNumber: 'INV-1234' });
    
    // html now contains rendered HTML ready for PDF generation or sending via email
-->
<html lang="en">

  <head>
    <meta charset="UTF-8" />
    <title>Invoice - {{invoiceNumber}}</title>
  </head>

  <body
    style="font-family: Arial, sans-serif; background-color: #f4f4f4; margin: 0; padding: 20px;"
  >
    <div
      style="max-width: 800px; margin: auto; background: #fff; border-radius: 6px; box-shadow: 0 0 10px rgba(0,0,0,0.1); overflow: hidden;"
    >
      <div style="padding: 20px; box-sizing: border-box;">
        <h2 style="margin-top: 0; color: #333;">Invoice - {{invoiceNumber}}</h2>
        <p>Dear Parent,</p>

        <p>Greetings from Institution! </p>

        <p>We hope you and your family are doing well.</p>

        <p>This is a kind reminder that the invoice for your child’s monthly
          course fee has been generated and is now available on the Student
          Management Portal. You may log in to review or download the invoice at
          your convenience.</p>

        <p>We kindly request you to complete the payment on or before the 10th
          of this month to avoid any late fees or service interruptions.</p>

        <p>Should you have any questions or require assistance with the portal,
          please feel free to reach out to +971 800 509 or
          contact@Institution.com.</p>

        <p>Thank you for your continued support and cooperation.</p>

        <p>Warm Regards,<br /><br />Institution</p>
      </div>
    </div>
  </body>

</html>